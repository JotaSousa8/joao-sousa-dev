{
  "info": {
    "name": "João Sousa — Analytics API",
    "description": "Pageviews + summary for joaosousadev.me analytics backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5095"
    },
    {
      "key": "apiKey",
      "value": "local-dev-key"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Record pageview",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"path\": \"/\",\n  \"referrer\": \"https://www.linkedin.com/\",\n  \"language\": \"pt-PT\",\n  \"screenWidth\": 1920,\n  \"screenHeight\": 1080,\n  \"utmSource\": \"linkedin\",\n  \"utmMedium\": \"social\",\n  \"utmCampaign\": \"profile\",\n  \"utmContent\": \"\",\n  \"utmTerm\": \"\"\n}"
        },
        "url": "{{baseUrl}}/api/analytics/pageview"
      }
    },
    {
      "name": "Summary (stats)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Api-Key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/analytics/summary?from=2026-07-01T00:00&to=2026-07-31T23:59&limit=200"
      }
    },
    {
      "name": "Schema",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-Api-Key",
            "value": "{{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/analytics/schema"
      }
    },
    {
      "name": "SQL query (read-only)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Api-Key",
            "value": "{{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sql\": \"SELECT Id, OccurredAtUtc, Path, ClientIp, Country FROM PageViews ORDER BY OccurredAtUtc DESC LIMIT 50\"\n}"
        },
        "url": "{{baseUrl}}/api/analytics/query"
      }
    }
  ]
}
